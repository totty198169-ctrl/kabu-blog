---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CATEGORY_SLUGS } from '../consts';
import { CATEGORIES } from '../content.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero">
    <h1>{SITE_TITLE}</h1>
    <p class="lead">{SITE_DESCRIPTION}</p>
    <ul class="cat-links">
      {
        CATEGORIES.map((cat) => (
          <li>
            <a href={`/category/${CATEGORY_SLUGS[cat]}/`}>{cat}</a>
          </li>
        ))
      }
    </ul>
  </section>

  <section aria-label="記事一覧">
    <h2 class="section-title">記事一覧</h2>
    {
      posts.length === 0 ? (
        <p>まだ記事がありません。</p>
      ) : (
        posts.map((post) => (
          <PostCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            ticker={post.data.ticker}
          />
        ))
      )
    }
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .lead {
    color: var(--color-muted);
    margin: 0.5rem 0 1.25rem;
  }
  .cat-links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }
  .cat-links a {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4em 0.9em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
  }
  .cat-links a:hover {
    text-decoration: none;
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .section-title {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }
</style>
