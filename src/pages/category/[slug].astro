---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../content.config';
import { CATEGORY_SLUGS, CATEGORY_DESCRIPTIONS } from '../../consts';

export const getStaticPaths = (async () => {
  return CATEGORIES.map((category) => ({
    params: { slug: CATEGORY_SLUGS[category] },
    props: { category },
  }));
}) satisfies GetStaticPaths;

const { category } = Astro.props;
const posts = (
  await getCollection(
    'blog',
    ({ data }) => !data.draft && data.category === category
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${category}の記事`} description={CATEGORY_DESCRIPTIONS[category]}>
  <section class="cat-hero">
    <p class="crumb"><a href="/">トップ</a> / カテゴリ</p>
    <h1>{category}</h1>
    <p class="lead">{CATEGORY_DESCRIPTIONS[category]}</p>
  </section>

  {
    posts.length === 0 ? (
      <p>このカテゴリの記事はまだありません。</p>
    ) : (
      posts.map((post) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          ticker={post.data.ticker}
        />
      ))
    )
  }
</BaseLayout>

<style>
  .cat-hero {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .crumb {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--color-muted);
    margin: 0.5rem 0 0;
  }
</style>
