---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags, ticker } =
  Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <div class="meta">
        <CategoryBadge category={category} />
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="updated">
              (更新: <FormattedDate date={updatedDate} />)
            </span>
          )
        }
      </div>
      <h1>{title}</h1>
      {ticker && <p class="ticker">銘柄コード: {ticker}</p>}
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((tag) => (
              <li>#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>

    <p class="back"><a href="/">← 記事一覧へ戻る</a></p>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }
  .ticker {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0.5rem 0 0;
  }
  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0.75rem 0 0;
  }
  .tags li {
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .prose :global(h2) {
    margin-top: 2.2rem;
    font-size: 1.4rem;
  }
  .prose :global(h3) {
    margin-top: 1.6rem;
    font-size: 1.15rem;
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0;
  }
  .back {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.95rem;
  }
</style>
